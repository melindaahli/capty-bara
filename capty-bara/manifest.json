{
  "manifest_version": 3,
  "name": "Capty-bara",
  "version": "1.0.0",
  "description": "Dual-language subtitle overlay for YouTube",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["src/content/index.jsx"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/logo.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
        "matches": [
        "https://www.youtube.com/watch*",
        "https://m.youtube.com/watch*"
        ],
        "js": ["src/content/index.jsx"],
        "css": [],
        "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/logo.png",
    "128": "icons/icon128.png"
  }
}
